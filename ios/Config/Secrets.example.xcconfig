// Secrets.example.xcconfig — template. Copy to Secrets.xcconfig and fill in.
//
//   cp Config/Secrets.example.xcconfig Config/Secrets.xcconfig
//
// Secrets.xcconfig is gitignored. The anon key is the *publishable* key (safe
// for client apps, protected by RLS) — the same one the web client uses in
// client/.env.local (VITE_SUPABASE_ANON_KEY).
//
// NOTE: xcconfig treats `//` as a comment, so the URL scheme's slashes must be
// escaped with $() — write `https:/$()/your-project.supabase.co`.

SUPABASE_URL = https:/$()/your-project.supabase.co
SUPABASE_ANON_KEY = your-publishable-anon-key
